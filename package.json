{
  "name": "math-tutor-ai",
  "version": "1.0.0",
  "private": true,
  "description": "Flask math tutor app controlled with npm scripts",
  "scripts": {
    "start": "python app.py",
    "dev": "python app.py",
    "open": "powershell -NoProfile -Command \"Start-Process 'http://127.0.0.1:5000'\"",
    "dev:open": "powershell -NoProfile -Command \"Start-Process 'http://127.0.0.1:5000'\" && python app.py"
  }
}
